# ============================
# Backend 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 값 채우기
# cp .env.example .env
# ============================

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=여기에_anon_key
SUPABASE_SECRET_KEY=여기에_secret_key

# OpenAI API
OPENAI_API_KEY=여기에_openai_api_key

# Web Push (나중에)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# 환경
ENV=development
